PORT=3000
NODE_ENV=development

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS CodeCommit
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-southeast-1

# Discord — ใช้ bot token (แนะนำ) หรือ webhook อย่างใดอย่างหนึ่ง
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=1234567890123456789
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxx/xxxxxxxxxx

# Local Discord Bot (npm run bot)
# ถ้าใช้ Identity Center ให้ update ค่าเหล่านี้ทุก 8 ชม.
# AWS_ACCESS_KEY_ID และ AWS_SECRET_ACCESS_KEY ด้านบนจะถูกใช้อัตโนมัติโดย bot
